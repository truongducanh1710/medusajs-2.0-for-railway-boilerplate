ller_nid": "templates_index_producttemplate", "callee": "join", "is_member_call": true, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L353"}, {"caller_nid": "templates_index_producttemplate", "callee": "filter", "is_member_call": true, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L353"}, {"caller_nid": "templates_index_producttemplate", "callee": "format", "is_member_call": true, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L356"}, {"caller_nid": "templates_index_producttemplate", "callee": "(() => {\r\n              let reviews: { rating: number }[] = []\r\n              try { reviews = JSON.parse(meta(product, \"reviews\") || \"[]\") } catch {}\r\n              const total = reviews.length\r\n              const avg = total > 0\r\n                ? (reviews.reduce((s, r) => s + r.rating, 0) / total).toFixed(1)\r\n                : \"4.8\"\r\n              const displayTotal = total > 0 ? total : 1247\r\n              const stars = Math.round(parseFloat(avg))\r\n              return (\r\n                <div className=\"flex items-center gap-2 flex-wrap\">\r\n                  <span className=\"text-orange-400 text-base\">{\"\u2605\".repeat(stars)}{\"\u2606\".repeat(5 - stars)}</span>\r\n                  <span className=\"text-sm font-bold text-gray-800\">{avg}</span>\r\n                  <span className=\"text-sm text-gray-400\">({displayTotal.toLocaleString(\"vi-VN\")} \u0111\u00e1nh gi\u00e1)</span>\r\n                  <span className=\"text-sm text-green-600 font-semibold\">\u25cf C\u00f2n h\u00e0ng</span>\r\n                </div>\r\n              )\r\n            })", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L396"}, {"caller_nid": "templates_index_producttemplate", "callee": "(() => {\r\n              const bullets: string[] = []\r\n              for (let i = 1; i <= 4; i++) {\r\n                const icon = meta(product, `benefit_icon_${i}`)\r\n                const title = meta(product, `benefit_title_${i}`)\r\n                if (title) bullets.push(`${icon || \"\u2705\"} ${title}`)\r\n              }\r\n              if (!bullets.length) return null\r\n              return (\r\n                <div className=\"flex flex-col gap-1.5\">\r\n                  {bullets.slice(0, 3).map((b, i) => (\r\n                    <div key={i} className=\"flex items-center gap-2 text-sm text-gray-700 font-medium\">\r\n                      <span>{b}</span>\r\n                    </div>\r\n                  ))}\r\n                </div>\r\n              )\r\n            })", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L426"}, {"caller_nid": "templates_index_producttemplate", "callee": "Number", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L469"}, {"caller_nid": "templates_index_producttemplate", "callee": "Number", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L530"}, {"caller_nid": "templates_index_producttemplate", "callee": "Number", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\modules\\products\\templates\\index.tsx", "source_location": "L531"}, {"caller_nid": "templates_index_producttemplate", "callee": "Number", "is_member_call": false, "source_file": "D:\\APP 2026\\phanvietweb\\_deploy_fix_repo\\storefront\\src\\mo